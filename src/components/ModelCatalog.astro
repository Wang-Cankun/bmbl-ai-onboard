---
import models from '../data/models.json';

const featured = models.find(m => m.recommended);
const others = models.filter(m => !m.recommended);

const badgeStyles: Record<string, string> = {
  general: 'bg-slate-100 text-slate-600',
  code: 'bg-scarlet-50 text-scarlet-600',
  reasoning: 'bg-amber-50 text-amber-700'
};
---

<section id="models" class="max-w-5xl mx-auto px-6 py-20 lg:py-28">
  <div class="flex items-center gap-3 mb-4">
    <div class="w-5 h-px bg-scarlet-500"></div>
    <p class="text-sm font-semibold tracking-[0.15em] uppercase text-scarlet-500">Models</p>
  </div>
  <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 tracking-tight">
    Choose your model
  </h2>
  <p class="mt-3 text-slate-500 max-w-lg">
    From fast general-purpose to specialized reasoning and code generation. All through a single endpoint.
  </p>

  <!-- Featured model -->
  {featured && (
    <div class="mt-12 p-6 lg:p-8 border-l-4 border-scarlet-500 bg-slate-50">
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class={`text-[0.65rem] font-semibold tracking-[0.15em] uppercase px-2 py-0.5 rounded-sm ${badgeStyles[featured.badge]}`}>
          {featured.badge}
        </span>
        <span class="text-[0.65rem] font-semibold tracking-[0.15em] uppercase px-2 py-0.5 rounded-sm bg-scarlet-500 text-white">
          Recommended
        </span>
      </div>
      <h3 class="text-2xl font-bold text-slate-900">{featured.name}</h3>
      <p class="mt-1 text-slate-600">{featured.description}</p>
      <div class="mt-3 flex flex-wrap gap-x-6 gap-y-1 text-sm text-slate-400">
        <span>{featured.context} context</span>
        <span>{featured.pricing.input} input / {featured.pricing.output} output {featured.unit}</span>
      </div>
    </div>
  )}

  <!-- Other models -->
  <div class="mt-6 divide-y divide-slate-200">
    {others.map(model => (
      <div class="py-5 grid grid-cols-1 md:grid-cols-[1fr_auto] gap-3 items-start">
        <div>
          <div class="flex items-center gap-2.5 mb-1">
            <h3 class="text-lg font-semibold text-slate-900">{model.name}</h3>
            <span class={`text-[0.6rem] font-semibold tracking-[0.15em] uppercase px-2 py-0.5 rounded-sm ${badgeStyles[model.badge]}`}>
              {model.badge}
            </span>
          </div>
          <p class="text-slate-500 text-sm">{model.description}</p>
        </div>
        <div class="text-sm text-slate-400 md:text-right">
          <div>{model.context} context</div>
          <div>{model.pricing.input} / {model.pricing.output}</div>
        </div>
      </div>
    ))}
  </div>
</section>
