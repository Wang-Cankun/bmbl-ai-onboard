---
---

<section class="relative overflow-hidden bg-slate-50">
  <!-- Tech grid pattern -->
  <div
    class="absolute inset-0 opacity-[0.4]"
    style="background-image: linear-gradient(to right, #e9ecef 1px, transparent 1px), linear-gradient(to bottom, #e9ecef 1px, transparent 1px); background-size: 48px 48px;"
  ></div>
  <div
    class="absolute inset-0"
    style="background: radial-gradient(ellipse at 30% 50%, transparent 30%, #f8f9fa 75%);"
  ></div>

  <div class="relative max-w-5xl mx-auto px-6 pt-20 pb-20 lg:pt-28 lg:pb-24">
    <!-- Top bar -->
    <div class="flex items-center gap-3 mb-12">
      <div class="w-8 h-8 bg-scarlet-500 flex items-center justify-center">
        <span class="text-white text-xs font-bold tracking-wider">B</span>
      </div>
      <p class="text-sm font-medium tracking-wide text-slate-500">
        CATION — Ohio State University
      </p>
    </div>

    <h1
      class="text-5xl lg:text-7xl font-bold text-slate-900 tracking-tight"
    >
      CATION <span class="text-scarlet-500">AI</span>
    </h1>

    <p class="mt-5 text-lg lg:text-xl text-slate-500 max-w-lg" style="line-height: 1.5;">
      Research-grade AI models for every lab member. One endpoint, every model.
    </p>

    <div class="mt-10 flex flex-wrap gap-6 sm:gap-10">
      <div class="flex items-baseline gap-2">
        <span class="text-3xl font-bold text-slate-900">6</span>
        <span class="text-xs font-medium tracking-[0.15em] uppercase text-slate-400">models</span>
      </div>
      <div class="flex items-baseline gap-2">
        <span class="text-3xl font-bold text-slate-900">1</span>
        <span class="text-xs font-medium tracking-[0.15em] uppercase text-slate-400">API key</span>
      </div>
      <div class="flex items-baseline gap-2">
        <span class="text-3xl font-bold text-slate-900">0</span>
        <span class="text-xs font-medium tracking-[0.15em] uppercase text-slate-400">config</span>
      </div>
    </div>

    <div class="mt-10 flex flex-wrap items-center gap-4">
      <a
        href="#get-started"
        class="inline-flex items-center gap-2 px-6 py-3 bg-scarlet-500 text-white text-sm font-semibold tracking-wide hover:bg-scarlet-600 transition-colors"
      >
        Get Started
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
      </a>
      <a
        href="#models"
        class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold tracking-wide text-slate-600 hover:text-slate-900 border border-slate-300 hover:border-slate-400 transition-colors"
      >
        View Models
      </a>
    </div>
  </div>
</section>
