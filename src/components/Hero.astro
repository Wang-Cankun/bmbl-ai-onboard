---
---

<section class="relative overflow-hidden">
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: radial-gradient(circle, oklch(0.44 0.19 27) 1px, transparent 1px); background-size: 24px 24px;"
  ></div>

  <div class="relative max-w-5xl mx-auto px-6 pt-24 pb-20 lg:pt-32 lg:pb-28">
    <p class="text-sm font-medium tracking-[0.2em] uppercase text-warm-500 mb-8">
      Biomedical &amp; Machine Learning Lab — Ohio State University
    </p>

    <h1
      class="font-display"
      style="font-size: clamp(3.5rem, 10vw, 7rem); line-height: 0.95; letter-spacing: -0.02em;"
    >
      BMBL<br />
      <span class="text-scarlet-500">AI</span>
    </h1>

    <p class="mt-8 text-xl lg:text-2xl text-warm-700 max-w-lg" style="line-height: 1.4;">
      Research-grade AI models for every lab member.
    </p>

    <div class="mt-12 flex flex-wrap gap-x-12 gap-y-4 text-warm-600">
      <div>
        <span class="font-display text-3xl text-warm-900 italic">6</span>
        <span class="ml-1.5 text-sm tracking-wide uppercase">models</span>
      </div>
      <div>
        <span class="font-display text-3xl text-warm-900 italic">1</span>
        <span class="ml-1.5 text-sm tracking-wide uppercase">API key</span>
      </div>
      <div>
        <span class="font-display text-3xl text-warm-900 italic">0</span>
        <span class="ml-1.5 text-sm tracking-wide uppercase">configuration</span>
      </div>
    </div>

    <a
      href="#get-started"
      class="inline-block mt-12 px-8 py-3.5 bg-scarlet-500 text-white text-sm font-semibold tracking-wide uppercase hover:bg-scarlet-600 transition-colors"
    >
      Get Started
    </a>
  </div>

  <div class="h-px bg-scarlet-200 max-w-5xl mx-auto"></div>
</section>
