---
import usage from '../data/usage.json';

const topModels = usage.byModel.slice(0, 5);
const maxReqs = Math.max(...topModels.map(m => m.requests));

function formatTokens(n: number): string {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M`;
  if (n >= 1_000) return `${(n / 1_000).toFixed(0)}K`;
  return String(n);
}
---

<section id="usage" class="bg-slate-50 border-y border-slate-200">
  <div class="max-w-5xl mx-auto px-6 py-20 lg:py-28">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-5 h-px bg-scarlet-500"></div>
      <p class="text-sm font-semibold tracking-[0.15em] uppercase text-scarlet-500">Usage</p>
    </div>
    <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 tracking-tight">
      Recent activity
    </h2>
    <p class="mt-3 text-slate-500">
      Gateway usage for {usage.period}. Updated {usage.lastUpdated}.
    </p>

    <!-- Stat cards -->
    <div class="mt-10 grid grid-cols-3 gap-4">
      <div class="bg-white border border-slate-200 p-5">
        <p class="text-3xl font-bold text-slate-900">{usage.totals.requests}</p>
        <p class="text-xs font-medium tracking-[0.1em] uppercase text-slate-400 mt-1">requests</p>
      </div>
      <div class="bg-white border border-slate-200 p-5">
        <p class="text-3xl font-bold text-slate-900">{formatTokens(usage.totals.tokens)}</p>
        <p class="text-xs font-medium tracking-[0.1em] uppercase text-slate-400 mt-1">tokens</p>
      </div>
      <div class="bg-white border border-slate-200 p-5">
        <p class="text-3xl font-bold text-slate-900">${usage.totals.spend.toFixed(2)}</p>
        <p class="text-xs font-medium tracking-[0.1em] uppercase text-slate-400 mt-1">total spend</p>
      </div>
    </div>

    <!-- Model breakdown with bar chart -->
    <div class="mt-8 bg-white border border-slate-200 p-6">
      <p class="text-sm font-semibold text-slate-700 mb-4">Requests by model</p>
      <div class="space-y-3">
        {topModels.map(m => (
          <div class="flex items-center gap-4">
            <span class="text-sm text-slate-600 w-32 shrink-0 truncate">{m.model}</span>
            <div class="flex-1 h-6 bg-slate-100 relative">
              <div
                class="h-full bg-scarlet-500/80"
                style={`width: ${(m.requests / maxReqs * 100).toFixed(1)}%`}
              ></div>
            </div>
            <span class="text-sm font-mono text-slate-400 w-12 text-right shrink-0">{m.requests}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Daily spend -->
    <div class="mt-4 bg-white border border-slate-200 p-6">
      <p class="text-sm font-semibold text-slate-700 mb-4">Daily spend</p>
      <div class="flex items-end gap-3 h-24">
        {usage.daily.map(d => {
          const maxSpend = Math.max(...usage.daily.map(x => x.spend));
          const pct = maxSpend > 0 ? (d.spend / maxSpend * 100) : 0;
          return (
            <div class="flex-1 flex flex-col items-center gap-1">
              <span class="text-xs font-mono text-slate-400">${d.spend.toFixed(2)}</span>
              <div class="w-full bg-slate-100 relative" style={`height: ${Math.max(pct, 4)}%`}>
                <div class="absolute inset-0 bg-scarlet-500/60"></div>
              </div>
              <span class="text-xs text-slate-400">{d.date}</span>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>
