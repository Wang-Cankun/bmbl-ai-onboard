---
const steps = [
  {
    label: 'Your Agent',
    title: 'OpenCode',
    desc: 'Claude Code, Cursor, or any OpenAI-compatible client',
    accent: false,
  },
  {
    label: 'CATION Gateway',
    title: 'Unified API',
    desc: 'Budget tracking, model routing, usage analytics',
    accent: true,
  },
  {
    label: 'Cloud Models',
    title: '6 Models',
    desc: 'GPT-5, MiniMax, GLM-5, Kimi, and more',
    accent: false,
  },
];
---

<section id="how-it-works" class="bg-slate-50 border-y border-slate-200">
  <div class="max-w-5xl mx-auto px-6 py-20 lg:py-28">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-5 h-px bg-scarlet-500"></div>
      <p class="text-sm font-semibold tracking-[0.15em] uppercase text-scarlet-500">Architecture</p>
    </div>
    <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 tracking-tight">
      How it works
    </h2>
    <p class="mt-3 text-slate-500 max-w-lg">
      One unified gateway. All models. Budget tracking and routing built in.
    </p>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-[1fr_auto_1fr_auto_1fr] gap-4 items-stretch">
      {steps.map((step, i) => (
        <>
          <div class={`p-6 flex flex-col ${step.accent ? 'bg-white border-2 border-scarlet-500 shadow-sm' : 'bg-white border border-slate-200'}`}>
            <p class={`text-xs font-semibold tracking-[0.15em] uppercase mb-3 ${step.accent ? 'text-scarlet-500' : 'text-slate-400'}`}>{step.label}</p>
            <p class="text-xl font-bold text-slate-900">{step.title}</p>
            <p class="mt-auto pt-3 text-sm text-slate-400">{step.desc}</p>
          </div>
          {i < steps.length - 1 && (
            <>
              <div class="hidden md:flex items-center justify-center text-slate-300 text-xl select-none">&rarr;</div>
              <div class="flex md:hidden items-center justify-center text-slate-300 text-xl py-1 select-none">&darr;</div>
            </>
          )}
        </>
      ))}
    </div>

    <div class="mt-10 flex items-center gap-3 px-5 py-3 bg-white border border-slate-200 w-fit">
      <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
      <code class="text-sm font-mono text-slate-600">https://bmblx.bmi.osumc.edu/ai/v1</code>
    </div>
  </div>
</section>
